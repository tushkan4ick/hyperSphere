FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      surfaceFeatureExtractDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


inlet.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       135;
}

outlet.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       135;
}

hyperSphere.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       135;
}

sphere.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       90;
}

symmetry_1.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       90;
}
symmetry_2.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       90;
}


